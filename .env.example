# ============================================================
# AEGIS — Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0

# Database (SQLite — file path relative to apps/api/)
DATABASE_URL="file:./aegis.db"

# LLM Provider: "gemini" | "deterministic" (default: deterministic)
# The app works fully without an API key using the deterministic fallback.
AEGIS_LLM_PROVIDER=deterministic

# Gemini API Key (only required if AEGIS_LLM_PROVIDER=gemini)
AEGIS_GEMINI_API_KEY=

# Reasoning cycle interval in milliseconds (default: 15000 = 15s)
AEGIS_CYCLE_MS=15000

# Context window: how many minutes of events to include (default: 30)
AEGIS_CONTEXT_WINDOW_MIN=30

# Recommendation TTL in minutes (default: 30)
AEGIS_REC_TTL_MIN=30

# Log level: "debug" | "info" | "warn" | "error" (default: info)
LOG_LEVEL=info

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
