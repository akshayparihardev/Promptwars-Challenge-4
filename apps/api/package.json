{
  "name": "@aegis/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/infrastructure/seed/seed.ts"
  },
  "dependencies": {
    "@aegis/shared": "*",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^9.3.0",
    "@google/genai": "^2.10.0",
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.3.3",
    "pino": "^9.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.1"
  }
}
